# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# CONFIGURAÇÃO DE APIs DE IA - RV-Adv
# ============================================

# NVIDIA NIM (Para análise processual - longo contexto)
VITE_NVIDIA_API_KEY=
VITE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq (Para geração de documentos e classificação - ALTA VELOCIDADE)
VITE_GROQ_API_KEY=
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter (Agregador - BACKUP UNIVERSAL)
VITE_OPENROUTER_API_KEY=

# Google AI Studio (Para OCR/Visão multimodal)
VITE_GEMINI_API_KEY=
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Cohere (Para classificação avançada - backup)
VITE_COHERE_API_KEY=

# Modelo padrão por funcionalidade
VITE_MODEL_WRITER=llama-3.3-70b-versatile
VITE_MODEL_VISION=gemini-2.0-flash
VITE_MODEL_CLASSIFIER=llama-3.1-8b-instant
VITE_MODEL_ANALYSIS=nvidia/nemotron-3-nano-30b-a3b
