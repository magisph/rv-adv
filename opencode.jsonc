{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "skills": {
    "aiox": {
      "enabled": true,
      "path": "aiox-core",
      "description": "Framework AIOX para desenvolvimento jurídico autônomo",
      "agents": [
        "dev",
        "qa",
        "architect",
        "po",
        "pm",
        "sm",
        "analyst",
        "data-engineer",
        "devops",
        "ux-expert",
        "aiox-master"
      ]
    }
  },
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "control-chrome": {
      "command": [
        "chrome-devtools-mcp"
      ],
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": [
    "opencode-scheduler"
  ],
  "model": "opencode/big-pickle",
  "compaction": {
    "auto": true
  }
}
