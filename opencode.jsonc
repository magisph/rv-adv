{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "control-chrome": {
      "command": [
        "chrome-devtools-mcp"
      ],
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": [
    "opencode-scheduler"
  ],
  "model": "opencode/big-pickle",
  "compaction": {
    "auto": true
  }
}
