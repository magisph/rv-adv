# ============================================================
# local-scraper/.env.example
# Copie para .env e preencha com os valores reais.
# NUNCA commitar o arquivo .env com dados reais.
# ============================================================

# Credenciais PJe (preenchidas automaticamente via /configurar/mni)
PJE_CPF=
PJE_SENHA=

# CNJ APIs
# Obtenha sua chave em: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=

# DJEN - Dados do advogado para monitoramento de publicações
DJEN_NUMERO_OAB=
DJEN_UF_OAB=
DJEN_NOME_ADVOGADO=
# Data de início da busca no formato YYYY-MM-DD (padrão: últimos 30 dias)
DJEN_DATA_INICIO=
