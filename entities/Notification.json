{
  "name": "Notification",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da notifica\u00e7\u00e3o"
    },
    "message": {
      "type": "string",
      "description": "Mensagem da notifica\u00e7\u00e3o"
    },
    "type": {
      "type": "string",
      "enum": ["prazo", "movimentacao", "sistema", "alerta", "compromisso"],
      "description": "Tipo da notifica\u00e7\u00e3o"
    },
    "read": {
      "type": "boolean",
      "default": false,
      "description": "Se foi lida"
    },
    "user_email": {
      "type": "string",
      "description": "E-mail do usu\u00e1rio destinat\u00e1rio"
    },
    "link": {
      "type": "string",
      "description": "Link para navega\u00e7\u00e3o"
    },
    "related_id": {
      "type": "string",
      "description": "ID do registro relacionado"
    },
    "scheduled_date": {
      "type": "string",
      "format": "date-time",
      "description": "Data agendada para envio"
    }
  },
  "required": ["title", "message", "type"],
  "rls": {
    "delete": {
      "$or": [
        {
          "user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
