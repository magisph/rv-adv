{
  "name": "DocumentVersion",
  "type": "object",
  "properties": {
    "document_id": {
      "type": "string",
      "description": "ID do documento principal"
    },
    "version_number": {
      "type": "integer",
      "description": "N\u00famero da vers\u00e3o"
    },
    "file_url": {
      "type": "string",
      "description": "URL do arquivo desta vers\u00e3o"
    },
    "notes": {
      "type": "string",
      "description": "Notas sobre esta vers\u00e3o"
    },
    "uploaded_by": {
      "type": "string",
      "description": "Email de quem fez upload"
    }
  },
  "required": ["document_id", "version_number", "file_url"],
  "rls": {
    "create": {
      "user_condition": {
        "role": {
          "$ne": "guest"
        }
      }
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
