{
  "name": "Template",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do template"
    },
    "content": {
      "type": "string",
      "description": "Conte\u00fado do template em HTML"
    },
    "category": {
      "type": "string",
      "enum": [
        "peticao_inicial",
        "recurso",
        "contestacao",
        "contrato",
        "procuracao",
        "notificacao",
        "outros"
      ],
      "description": "Categoria do template"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Lista de vari\u00e1veis utilizadas"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do template"
    }
  },
  "required": ["name", "content", "category"],
  "rls": {
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    }
  }
}
