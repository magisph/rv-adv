{
  "name": "ProcessMove",
  "type": "object",
  "properties": {
    "process_id": {
      "type": "string",
      "description": "ID do processo relacionado"
    },
    "process_number": {
      "type": "string",
      "description": "N\u00famero do processo para refer\u00eancia"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data da movimenta\u00e7\u00e3o"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da movimenta\u00e7\u00e3o"
    },
    "source": {
      "type": "string",
      "enum": ["datajud", "manual", "sistema"],
      "default": "manual",
      "description": "Fonte da movimenta\u00e7\u00e3o"
    },
    "move_type": {
      "type": "string",
      "enum": [
        "despacho",
        "sentenca",
        "decisao",
        "peticao",
        "intimacao",
        "citacao",
        "audiencia",
        "outros"
      ],
      "description": "Tipo da movimenta\u00e7\u00e3o"
    }
  },
  "required": ["process_id", "date", "description"],
  "rls": {
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    }
  }
}
