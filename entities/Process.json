{
  "name": "Process",
  "type": "object",
  "properties": {
    "process_number": {
      "type": "string",
      "description": "N\u00famero do processo (CNJ)"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente relacionado"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente para refer\u00eancia r\u00e1pida"
    },
    "court": {
      "type": "string",
      "description": "Tribunal/Vara"
    },
    "subject": {
      "type": "string",
      "description": "Assunto/\u00c1rea do direito"
    },
    "case_value": {
      "type": "number",
      "description": "Valor da causa"
    },
    "status": {
      "type": "string",
      "enum": ["ativo", "arquivado", "suspenso", "encerrado"],
      "default": "ativo",
      "description": "Status do processo"
    },
    "distribution_date": {
      "type": "string",
      "format": "date",
      "description": "Data de distribui\u00e7\u00e3o"
    },
    "area": {
      "type": "string",
      "enum": ["previdenciario", "civel", "procuradoria_mulher", "outros"],
      "description": "\u00c1rea do direito"
    },
    "last_move_date": {
      "type": "string",
      "format": "date",
      "description": "Data da \u00faltima movimenta\u00e7\u00e3o"
    }
  },
  "required": ["process_number", "client_id", "area"],
  "rls": {
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "user"
          }
        }
      ]
    }
  }
}
